---
interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<nav aria-label="面包屑" class="mb-6">
  <ol class="flex items-center gap-1.5 text-sm flex-wrap">
    <li>
      <a href="/" class="text-[#9898A6] hover:text-[#FF6B35] transition-colors">首页</a>
    </li>
    {items.map((item, index) => (
      <li class="flex items-center gap-1.5">
        <svg class="w-3.5 h-3.5 text-[#5A5A6E]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
        {item.href ? (
          <a href={item.href} class="text-[#9898A6] hover:text-[#FF6B35] transition-colors">
            {item.label}
          </a>
        ) : (
          <span class="text-[#E8E8ED]">{item.label}</span>
        )}
      </li>
    ))}
  </ol>
</nav>
