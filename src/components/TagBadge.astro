---
interface Props {
  label: string;
  active?: boolean;
  onClick?: string;
}

const { label, active = false, onClick } = Astro.props;
---

{onClick ? (
  <button
    data-action={onClick}
    class:list={[
      'inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium transition-colors cursor-pointer',
      active
        ? 'bg-[#FF6B35]/15 text-[#FF6B35]'
        : 'bg-[#2A2A3A]/50 text-[#9898A6] hover:bg-[#2A2A3A] hover:text-[#E8E8ED]'
    ]}
  >
    {label}
  </button>
) : (
  <span
    class:list={[
      'inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium',
      active
        ? 'bg-[#FF6B35]/15 text-[#FF6B35]'
        : 'bg-[#2A2A3A]/50 text-[#9898A6]'
    ]}
  >
    {label}
  </span>
)}
