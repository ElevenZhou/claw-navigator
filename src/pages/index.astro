---
import BaseLayout from '../layouts/BaseLayout.astro';
import HomeClient from '../components/HomeClient';
import CompareFloatBar from '../components/CompareFloatBar';
import productsData from '../data/products.json';

// Pass minimal data to client
const clientProducts = productsData.map(p => ({
  id: p.id,
  name: p.name,
  slogan: p.slogan,
  vendor: p.vendor,
  vendorGroup: p.vendorGroup,
  platformLabel: p.platformLabel,
  price: p.price,
  priceCategory: p.priceCategory,
  difficulty: p.difficulty,
  logoUrl: p.logoUrl,
  tagCategories: p.tagCategories,
  status: p.status,
  features: p.features,
}));

const floatBarProducts = productsData.map(p => ({
  id: p.id,
  name: p.name,
  logoUrl: p.logoUrl,
}));
---

<BaseLayout>
  <!-- Hero -->
  <section class="pt-24 pb-8 px-4 sm:px-6">
    <div class="max-w-7xl mx-auto text-center">
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-[#E8E8ED] mb-4">
        🦞 找到你的龙虾
      </h1>
      <p class="text-base sm:text-lg text-[#9898A6] max-w-2xl mx-auto mb-6">
        Claw/龙虾 AI Agent 生态导航 — 一站式发现、对比、选择最适合你的智能体
      </p>
      <div class="flex items-center justify-center gap-4 sm:gap-6 text-sm text-[#5A5A6E]">
        <span class="flex items-center gap-1.5">
          <span class="w-1.5 h-1.5 rounded-full bg-[#4ECDC4]"></span>
          {productsData.length}+ 款产品
        </span>
        <span class="flex items-center gap-1.5">
          <span class="w-1.5 h-1.5 rounded-full bg-[#FF6B35]"></span>
          10+ 厂商
        </span>
        <span class="flex items-center gap-1.5">
          <span class="w-1.5 h-1.5 rounded-full bg-[#6C5CE7]"></span>
          持续更新
        </span>
      </div>
    </div>
  </section>

  <!-- Search + Filter + Grid -->
  <section class="px-4 sm:px-6 pb-8">
    <div class="max-w-7xl mx-auto">
      <HomeClient client:load products={clientProducts} />
    </div>
  </section>
</BaseLayout>

<!-- JSON-LD Structured Data -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Claw Navigator",
  "description": "🦞 Claw/龙虾 AI Agent 生态导航 — 一站式发现、对比、选择最适合你的智能体",
  "url": "https://clawnav.com",
  "potentialAction": {
    "@type": "SearchAction",
    "target": "https://clawnav.com/?q={search_term_string}",
    "query-input": "required name=search_term_string"
  }
})} />

<!-- Product List JSON-LD -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Claw AI Agent 产品列表",
  "numberOfItems": productsData.length,
  "itemListElement": productsData.map((p, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "item": {
      "@type": "SoftwareApplication",
      "name": p.name,
      "description": p.slogan,
      "url": `https://clawnav.com/product/${p.id}`,
      "applicationCategory": "AI Agent",
      "operatingSystem": p.platformLabel,
      "offers": p.priceCategory === 'free' || p.priceCategory === 'open-source'
        ? { "@type": "Offer", "price": "0", "priceCurrency": "CNY" }
        : undefined
    }
  }))
})} />

<CompareFloatBar client:only="react" products={floatBarProducts} />
