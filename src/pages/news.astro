---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import newsData from '../data/news.json';
import type { NewsItem } from '../types/product';

// Group news by month
const monthGroups = new Map<string, NewsItem[]>();
for (const item of newsData) {
  const month = item.date.slice(0, 7); // YYYY-MM
  const list = monthGroups.get(month) || [];
  list.push(item);
  monthGroups.set(month, list);
}

const sortedMonths = Array.from(monthGroups.keys()).sort((a, b) => b.localeCompare(a));

const TYPE_CONFIG: Record<string, { label: string; color: string; bg: string }> = {
  release: { label: '发布', color: '#4ECDC4', bg: '#4ECDC415' },
  update: { label: '更新', color: '#FF6B35', bg: '#FF6B3515' },
  other: { label: '动态', color: '#6C5CE7', bg: '#6C5CE715' },
};

const MONTH_LABELS: Record<string, string> = {
  '2026-03': '2026年3月',
  '2026-02': '2026年2月',
  '2026-01': '2026年1月',
  '2025-12': '2025年12月',
  '2025-11': '2025年11月',
  '2025-10': '2025年10月',
  '2025-09': '2025年9月',
  '2025-08': '2025年8月',
};
---

<BaseLayout title="行业动态" description="Claw/龙虾 AI Agent 行业动态 — 追踪最新产品发布、版本更新和生态发展">
  <div class="pt-24 pb-16 px-4 sm:px-6">
    <div class="max-w-4xl mx-auto">

      <Breadcrumb items={[
        { label: '首页', href: '/' },
        { label: '行业动态' }
      ]} />

      <!-- Header -->
      <div class="text-center mb-12">
        <h1 class="text-3xl sm:text-4xl font-bold text-[#E8E8ED] mb-3">📰 行业动态</h1>
        <p class="text-[#9898A6]">
          追踪 Claw 生态最新产品发布、版本更新与行业事件
        </p>
      </div>

      <!-- Timeline -->
      {sortedMonths.map((month, mi) => {
        const items = monthGroups.get(month)!;
        const monthLabel = MONTH_LABELS[month] || month;
        return (
          <div class="mb-10 animate-fade-in">
            <!-- Month Header -->
            <div class="flex items-center gap-3 mb-6">
              <div class="w-3 h-3 rounded-full bg-[#FF6B35] flex-shrink-0"></div>
              <h2 class="text-lg font-bold text-[#E8E8ED]">{monthLabel}</h2>
              <div class="flex-1 h-px bg-[#2A2A3A]"></div>
              <span class="text-xs text-[#5A5A6E]">{items.length} 条</span>
            </div>

            <!-- News Items -->
            <div class="ml-1.5 border-l-2 border-[#2A2A3A] pl-6 sm:pl-8 space-y-6">
              {items.map((item, ii) => {
                const config = TYPE_CONFIG[item.type] || TYPE_CONFIG.other;
                const day = item.date.slice(8, 10);
                return (
                  <div class="relative group">
                    <!-- Timeline dot -->
                    <div
                      class="absolute -left-[2.65rem] sm:-left-[3.15rem] top-1.5 w-3 h-3 rounded-full border-2 border-[#0A0A0F] group-hover:scale-125 transition-transform"
                      style={`background: ${config.color}`}
                    ></div>

                    <!-- Card -->
                    <div class="bg-[#16161F] rounded-xl border border-[#2A2A3A] p-5 hover:border-[#3A3A4A] transition-colors">
                      <div class="flex items-center gap-3 mb-2 flex-wrap">
                        <span class="text-xs text-[#5A5A6E]">{day}日</span>
                        <span
                          class="px-2 py-0.5 rounded-full text-xs font-medium"
                          style={`background: ${config.bg}; color: ${config.color}`}
                        >
                          {config.label}
                        </span>
                        <span class="text-xs font-medium text-[#FF6B35]">{item.product}</span>
                      </div>

                      <h3 class="text-base font-bold text-[#E8E8ED] mb-2 group-hover:text-[#FF6B35] transition-colors">
                        {item.title}
                      </h3>
                      <p class="text-sm text-[#9898A6] leading-relaxed">{item.summary}</p>

                      {item.source && (
                        <a
                          href={item.source}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="inline-flex items-center gap-1 text-xs text-[#5A5A6E] hover:text-[#4ECDC4] mt-3 transition-colors"
                        >
                          <span>查看来源</span>
                          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                          </svg>
                        </a>
                      )}
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        );
      })}

    </div>
  </div>
</BaseLayout>
